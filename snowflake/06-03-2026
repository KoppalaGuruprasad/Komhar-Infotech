--How to find out the duplicates , what are the ways

--/using group by

select customer_id,product,amount,count(*) as duplicate_count
from sales_data
group by customer_id,product,amount
having count(*) >1;

--group by work as grooup the similar records
--count(*) counts the rows
--having count(*)>1 returns the duplicates

-- /row_number using sub query
select * from
(
select *,
row_number() over
(
partition by customer_id,product,amount order by created_ts
)as rn
from sales_data
)
where rn>1;

-- inside sub query finds the duplicates
--row number -assign a unique sequential number to each row.

--partition - divides table into groups based on the columns each unique column combination of columns and creates a separate group(partition)
-- then row number retarns from 1 inside evy partition
--inside every partition ,rows are sorted based on the timestamp.
-- we used this to remove duplicates "where rn=1"
--find duplicates "where rn>1"
--get latest record "order by created_ts desc"


--/count() over window function
select * from
(
select*,
count(*) over
(
partition by customer_id,product,amount
) as duplicate_count
from sales_data
)
where duplicate_count > 1;

select * from sales_data;
-- only inner query works - instead of grouping this counts the no.of rows inside each partition.

--where condition works as give only duplicate records.

--/using self join
select a.*
from sales_data a
join sales_data b
on a.customer_id = b.customer_id
and a.amount = b.amount
and a.product = b.product
and a.sale_id <> b.sale_id;

--a and b are copy of the table
-- then it will check matching conditions if these are same then rows may be duplicate
--" a.sale_id <> b.sale_id" - this compare different rows we use this to avoid matching same row.
--" select a.* " -it returns the rows from alias a  that have duplicates.

--/DISTINCT Comparison

select count(*) as total_rows,
count(distinct customer_id,product,amount)as unique_rows
from sales_data;

-- it only tells how many duplicate exist, not which records are duplicates

--/QUALIFY 

select * from sales_data
qualify row_number() over
(
partition by customer_id order by created_ts)>1;

-- qualify is used to filter results of window functions without using subqueries.
-- this is powerful  because snowflake allows filtering window functions directly , no need for subquery.
--it is a snowflake special feature
--if we use after qualify query we give " =1 " it will print the latest record per order.
--Normally sql executes window function after where ,we can't filter directly using where 
--that why we use qualify




--delete duplicates

--/row_number()


delete from sales_data
using
(
select *,
row_number() over (
partition by customer_id,product,amount order by created_ts desc
) as rn
from sales_data
)t
where sales_data.customer_id = t.customer_id
and sales_data.product=t.product
and sales_data.amount=t.amount
and sales_data.created_ts=t.created_ts
and t.rn>1;
select * from sales_data;
-- inside sub query works like it will assign row number for duplicate rows
-- this query works to delete duplicate records 
-- there is a problem like it will delete all rows for that customer


--/ using qualify

delete from sales_data
using
(
select * from sales_data
qualify row_number() over
(
partition by customer_id,product,amount
order by created_ts desc
)>1
)t 
where sales_data.customer_id = t.customer_id;

-- row number() -> identify duplicates
--qualify filters rows after window functions are calculated.select duplicates
--delete using -> remove duplicates


