--store procedure

create or replace procedure usp_insert_failed_students()
returns string
language sql
as
$$
begin

insert into failed_students
(std_id,std_name,marks,clg_id,status)

select
std_id,
std_name,
marks,
clg_id,
'failed'
from student
where marks<40;
return 'failed students inserted';
end;
$$;

