create or replace table fact_student
(
std_id int,
std_name string,
marks int,
clg_id int,
status string,
admission_date date
);

create or replace table student_error_log
(
std_id int,
error_reason string
);

--Instead of rejecting bad data completely, we log invalid records with a reason.

--insert invalid data

insert into student_error_log(std_id,error_reason)
select
std_id,
case
when marks <= 0 then 'invalid marks'
when marks > 100 then 'marks exceed limit'
when admission_date > current_date then 'future date'
when status is null then 'status missing'
when std_name is null then 'name missing'
end
from stg_student
where 
marks <=0 or
marks >100 or
admission_date > current_date or
status is null or 
std_name is null;

--Identifies bad records
--Assigns a specific error message
--Inserts them into error_log table


select * from student_error_log;

insert into fact_student
(std_id,std_name,marks,clg_id,status,admission_date)
select 
std_id,
std_name,
marks,
clg_id,
status,
admission_date from stg_student
where 
marks > 0 and
marks <=100 and
admission_date <=current_date and 
status is not null and 
std_name is not null;

--Only records passing all validation rules are inserted into fact_student.
select * from fact_student;


--store procedure
create or replace procedure simple_student_process()
returns string
language sql
as
$$
begin

-- Insert invalid students

insert into student_error_log(std_id,error_reason)
select
std_id,
case
when marks <= 0 then 'invalid marks'
when marks > 100 then 'marks exceed limit'
when admission_date > current_date then 'future date'
when status is null then 'status missing'
when std_name is null then 'name missing'
end
from stg_student
where 
marks <=0 or
marks >100 or
admission_date > current_date or
status is null or 
std_name is null;

-- Insert valid students
insert into fact_student
(std_id,std_name,marks,clg_id,status,admission_date)
select 
std_id,
std_name,
marks,
clg_id,
status,
admission_date from stg_student
where 
marks > 0 and
marks <=100 and
admission_date <=current_date and 
status is not null and 
std_name is not null;
RETURN 'STUDENT DATA PROCESSED SUCCESSFULLY';
exception
when other then
rollback;
return 'process failed';
END;
$$;

call simple_student_process();


Raw Student Data
      ↓
stg_student (Staging)
      ↓
Validation Rules
      ↓
Invalid Data → student_error_log
      ↓
Valid Data → fact_student




