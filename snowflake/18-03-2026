--------------------------------------------------CTE based scenario questions ----------------------------------------------


--- get employees with above average salary 

with cte as 
(
select avg(salary) as avg_salary
from employee
)
select emp_name,salary
from employee,cte
where salary >avg_salary;

--- find highest salary in each department

with cte as 
(
select dept_id, max(salary) as max_salary
from employee group by dept_id
)
select e.emp_name, e.salary from employee e 
join cte c 
on e.dept_id = c.dept_id
and e.salary = c.max_salary;

---get employees with there manager names 

with cte as 
(
select e.emp_name, m.manager_name
from employee e
join manager m
on e.manager_id = m.manager_id
)
select * from cte;

---get employee count per department 

with cte as(
select dept_id, count(*) as cnt
from employee
group by dept_id
)
select d.dept_name,c.cnt from cte c 
join department d 
on c.dept_id = d.dept_id;

---find employees without departments

with cte as 
(
select * from employee where dept_id is null 
)
select emp_name from cte;



