------------cdc---------------

merge into employee tgt 
using stg_employee src 
on tgt.emp_id = src.emp_id

when matched then 
update set
tgt.emp_name = src.emp_name,
tgt.salary = src.salary

when not matched then 
insert (emp_id, emp_name, dept_id,manager_id, salary)
values (src.emp_id, src.emp_name, src.dept_id, src.manager_id, src.salary);


-------update only if salary changed -----------

merge into employee tgt 
using stg_employee src 
on tgt.emp_id = src.emp_id

when matched and tgt.salary != src.salary then 
update set tgt.salary =src.salary;


