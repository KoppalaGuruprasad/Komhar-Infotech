--------------------------------------------------------window functions -------------------------------------

---find ranking of employees based on salary 

select emp_name,salary, 
rank() over (order by salary desc) as rank
from employee;


---find employees ranking inside each department

select emp_name, dept_id, salary,
rank() over(partition by dept_id order by salary desc) as dept_rank
from employee;


---find highest paid employee per department

with cte as 
(
select *,
row_number() over (partition by dept_id order by salary desc) as rn 
from employee
)
select * from cte
where rn=1;

---remove duplocate employees

with cte as (
select *,
row_number() over(partition by emp_name order by emp_id) as rn
from employee
)
select * from cte
where rn =1;

--- compare employee salary wit previous employee

select emp_name, salary,
lag(salary) over ( order by salary ) as prev_salary
from employee;

---compare salary with next employee

select emp_name, salary,
lead(salary) over (order by salary ) as next_salary
from employee;

--- running total salary 

select emp_name, dept_id, salary,
sum(salary) over (order by emp_id) as running_total
from employee;


--- department wise total salary 

select emp_name, dept_id, salary,
sum(salary) over (partition by dept_id) as dept_total
from employee;

--- Average salary per department

select emp_name, dept_id, salary,
avg(salary) over ( partition by dept_id) as dept_avg
from employee;



