select 
c.customer_name,
c.city,
sum(f.amount) as Total_Revenue,
count(f.order_id) as Total_Orders,
case 
when Total_Revenue>20000 then 'Platinum'
when Total_Revenue>10000 then 'Gold'
else 'silver'
end as Revenue
from dim_customer c
join fact_orders f
on c.customer_id = f.customer_id
group by c.customer_name,c.city;



select * from 
(
select c.customer_name,
c.city,
sum(f.amount) as Total_revenue,
row_number() over (
partition by c.city order by sum(f.amount) desc) as rn
from dim_customer c
join fact_orders f
on c.customer_id = f.customer_id
group by
c.customer_name,
c.city
)t
where rn <=3;



create or replace view VW_ACTIVE_CUSTOMER_REVENUE as
select 
c.customer_name,
c.city,
c.is_active,
sum(f.amount) as revenue,
count(f.order_id) as orders,
case
when revenue >= 12000 then '20% discount'
when revenue >=7000 then '10% discount'
else 'No Discount'
end as Discount
from dim_customer c
join fact_orders f
on c.customer_id = f.customer_id
group by c.customer_name,c.city,c.is_active
having 
c.is_active = True
and count(f.order_id)>2
and sum(f.amount)>5000;

