select * from stg_orders;
select * from fact_orders;

merge into fact_orders t
using stg_orders s
on t.order_id = s.order_id
when matched and s.status='cancelled'
then delete
when matched
then update set
t.customer_id = s.customer_id,
t.order_date = s.order_date,
t.amount = s.amount,
t.status = s.status,
t.updated_ts = current_timestamp
when not matched
then insert
(order_id, customer_id, order_date, amount, status, created_ts, updated_ts)
values
(s.order_id, s.customer_id, s.order_date, s.amount, s.status, current_timestamp, current_timestamp);

