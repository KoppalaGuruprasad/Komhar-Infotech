
CREATE OR REPLACE TABLE DIM_CUSTOMER ( 
CUSTOMER_ID INT, 
CUSTOMER_NAME STRING, 
CITY STRING, 
CREATED_DATE DATE, 
IS_ACTIVE BOOLEAN, 
CUSTOMER_TYPE STRING 
);

CREATE OR REPLACE TABLE FACT_ORDERS ( 
ORDER_ID INT, 
CUSTOMER_ID INT, 
ORDER_DATE DATE, 
AMOUNT NUMBER(10,2), 
STATUS STRING, 
CREATED_TS TIMESTAMP, 
UPDATED_TS TIMESTAMP 
); 

CREATE OR REPLACE TABLE STG_ORDERS ( 
ORDER_ID INT, 
CUSTOMER_ID INT, 
ORDER_DATE DATE, 
AMOUNT NUMBER(10,2), 
STATUS STRING 
); 
